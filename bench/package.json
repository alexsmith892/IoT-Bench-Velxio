{
  "name": "iot-bench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "IoT-Bench — headless grading harness for LLM-authored firmware on Velxio (AVR PoC).",
  "scripts": {
    "task": "tsx runner/cli.ts",
    "gate:run": "tsx gate/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "gate": "vitest run __tests__/tasks __tests__/gate.task.test.ts",
    "gate:struct": "vitest run __tests__/families",
    "gate:d1": "vitest run __tests__/tasks/active-low-interlock __tests__/tasks/dual-input-safety-enable __tests__/tasks/hex-dip-to-7segment __tests__/tasks/potentiometer-pwm-map __tests__/tasks/tmp36-calibrated-report __tests__/tasks/uno-led-blink",
    "gate:d2": "vitest run __tests__/tasks/debounced-toggle __tests__/tasks/integer-overflow-accumulator __tests__/tasks/light-alarm-hysteresis __tests__/tasks/responsive-dual-scheduler __tests__/tasks/rolling-adc-average __tests__/tasks/serial-control-protocol",
    "gate:d3": "vitest run __tests__/tasks/appliance-cycle-fsm __tests__/tasks/four-mode-indicator __tests__/tasks/reaction-timer-fsm",
    "export:inspection": "tsx scripts/export-inspection-scenarios.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "avr8js": "0.21.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
